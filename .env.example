# Copy this file to .env and fill in your values.
# .env is git-ignored.

# Anthropic Claude API key for the planner.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default planning model.
# Default is claude-sonnet-4-6. Use claude-opus-4-7 for tricky multi-leg plans.
# FLYMAX_MODEL=claude-sonnet-4-6
